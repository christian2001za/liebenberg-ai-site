---
import "../index.css";
import GrainOverlay from "../components/design/GrainOverlay";
import DynamicGradientBackground from "../components/design/DynamicGradientBackground";

import logo from "../assets/logo.svg";

const {
  title = "Liebenberg AI - Custom AI oplossingen .",
  description = "Liebenberg AI - Custom AI oplossingen .",
  canonical = "https://www.liebenberg.ai/",
  image = "/icon.PNG",
  type = "website",
} = Astro.props;

const isHome = Astro.url.pathname === "/";
const anchor = (id: string) => (isHome ? `#${id}` : `/#${id}`);
const logoSrc = typeof logo === "string" ? logo : logo.src;
const ogImage = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Liebenberg AI" />
    <link rel="canonical" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500;1,6..72,600&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@liebenberg_ai" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Analytics (cookieloos) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G9SN9V0NGW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        'analytics_storage': 'denied'
      });
      gtag('js', new Date());
      gtag('config', 'G-G9SN9V0NGW');
    </script>
  </head>
  <body>
    <GrainOverlay />
    <DynamicGradientBackground client:only="react" />
    <header class="px-6 py-6 fixed top-0 w-full z-40 bg-[#fafae9]/70 backdrop-blur-[20px]">
      <div class="mx-auto flex max-w-6xl items-center justify-between">
        <a href="/" aria-label="Liebenberg AI">
          <img
            src={logoSrc}
            alt="Liebenberg AI"
            class="h-6 w-auto"
          />
        </a>
        <div class="hidden md:flex items-center gap-8">
          <nav class="flex gap-8 label-uppercase text-muted-foreground">
            <a href={anchor("diensten")} class="hover:text-foreground transition-colors">Expertise</a>
            <a href={anchor("werkwijze")} class="hover:text-foreground transition-colors">Werkwijze</a>
            <a href={anchor("cases")} class="hover:text-foreground transition-colors">Cases</a>
            <a href={anchor("contact")} class="hover:text-foreground transition-colors">Contact</a>
          </nav>
          <a
            href="/blog/"
            class="label-uppercase text-muted-foreground hover:text-foreground transition-colors"
          >
            Blog
          </a>
        </div>
        <div class="md:hidden flex items-center gap-4">
          <a
            href={anchor("contact")}
            class="label-uppercase text-muted-foreground hover:text-foreground transition-colors"
          >
            Contact
          </a>
          <a
            href="/blog/"
            class="label-uppercase text-muted-foreground hover:text-foreground transition-colors"
          >
            Blog
          </a>
        </div>
      </div>
    </header>
    <slot />
    <footer class="py-8 relative z-10 bg-surface-high">
      <div class="mx-auto max-w-6xl px-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-muted-foreground">
        <div class="flex flex-col md:flex-row items-center gap-4">
          <p>&copy; 2026 Liebenberg AI. Alle rechten voorbehouden.</p>
          <a href="/privacyverklaring" class="hover:text-foreground transition-colors">Privacyverklaring</a>
          <a href="/algemene-voorwaarden" class="hover:text-foreground transition-colors">Algemene Voorwaarden</a>
        </div>
        <p>KvK nummer: 98456598</p>
      </div>
    </footer>
  </body>
</html>
