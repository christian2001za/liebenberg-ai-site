---
import BaseLayout from "../../layouts/BaseLayout.astro";

const tools = [
  {
    title: "AI Humanizer",
    description:
      "Plak AI-gegenereerde tekst en krijg een natuurlijkere, menselijkere versie terug. Gratis, zonder account.",
    href: "/tools/humanizer/",
    cta: "Open tool",
  },
];
---

<BaseLayout
  title="Tools — Liebenberg AI"
  description="Gratis AI-tools van Liebenberg AI. Praktische hulpmiddelen voor het werken met taalmodellen, geen account vereist."
  canonical="https://www.liebenberg.ai/tools/"
>
  <main class="px-6 py-24 md:py-32">
    <section class="mx-auto max-w-3xl mb-16">
      <span class="label-uppercase text-muted-foreground">Tools</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-heading">Gratis AI-tools.</h1>
      <p class="mt-6 text-lg text-muted-foreground leading-relaxed">
        Kleine, praktische hulpmiddelen die we zelf gebruiken. Geen account,
        geen e-mail, geen gedoe — open en gebruiken.
      </p>
    </section>

    <section class="mx-auto max-w-3xl">
      <ul class="space-y-px">
        {
          tools.map((tool) => (
            <li>
              <a
                href={tool.href}
                class="group block bg-card ghost-border-20 p-8 md:p-10 hover:bg-secondary transition-colors"
              >
                <div class="flex items-baseline justify-between gap-6">
                  <h2 class="font-heading text-2xl md:text-3xl">{tool.title}</h2>
                  <span class="label-uppercase text-muted-foreground group-hover:text-foreground transition-colors shrink-0">
                    {tool.cta} →
                  </span>
                </div>
                <p class="mt-4 text-muted-foreground leading-relaxed">
                  {tool.description}
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>
